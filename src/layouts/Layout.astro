---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const { 
	title = "FV Automotores - Selección Exclusiva", 
	description = "25 años de trayectoria garantizando tu próximo vehículo seleccionado." 
} = Astro.props;

---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="{description}">
    <title>{title}</title>
    <link rel="preload" href="/fonts/Microgramma-Bold-Extended.otf" as="font" type="font/otf" crossorigin="anonymous" />
    <ClientRouter />
</head>
<body>
    <main>
        <slot />
    </main>
</body>
</html>