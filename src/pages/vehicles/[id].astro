---
import Layout from "@/layouts/Layout.astro";
import Footer from "@/sections/Footer.astro";
import Header from "@/sections/Header.astro";
import Button from "@/components/Button.astro";
import VehicleBadge from "@/components/VehicleBadge.astro";
import VehicleCard from "@/components/VehicleCard.astro";
import { VEHICLES } from "@/data/vehicles";
import type { Vehicle } from "@/types/vehicle";

interface Props {
  vehicle: Vehicle;
}

export function getStaticPaths(): any[] {
  return VEHICLES.map((vehicle) => ({
    params: { id: vehicle.id },
    props: { vehicle },
  }));
}

const { vehicle } = Astro.props as Props;
const relatedVehicles = VEHICLES.filter((relatedVehicle) => relatedVehicle.id !== vehicle.id);
---

<Layout title={vehicle.name}>
  <Header />
  <main class="w-full mt-6 min-h-screen bg-fvantracita-950 py-12">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid items-start gap-8 lg:grid-cols-[minmax(0,1.65fr)_minmax(320px,0.95fr)] xl:grid-cols-[minmax(0,1.8fr)_minmax(360px,1fr)]">
        <!-- Image Gallery Section -->
        <div class="flex flex-col gap-6">
          <div class="relative overflow-hidden rounded-lg bg-fvantracita-900 h-96 lg:h-125">
            <img
              id="mainImage"
              src={vehicle.image}
              alt={vehicle.name}
              class="h-full w-full object-cover"
            />

            <button
              id="prevBtn"
              class="absolute left-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/50 p-3 text-white transition hover:bg-black/75"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
              </svg>
            </button>

            <button
              id="nextBtn"
              class="absolute right-4 top-1/2 z-10 -translate-y-1/2 rounded-full bg-black/50 p-3 text-white transition hover:bg-black/75"
            >
              <svg class="h-6 w-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </button>

            <div class="absolute right-4 top-4 rounded-full bg-black/70 px-3 py-1 text-sm font-bold text-white">
              <span id="imageCounter">1</span> / <span id="totalImages">4</span>
            </div>
          </div>

          <div class="flex gap-3 overflow-x-auto pb-2">
            <button class="thumbnail active shrink-0 h-20 w-20 overflow-hidden rounded-lg border-2 border-fvplata-300 transition hover:border-fvplata-100" data-index="0">
              <img src={vehicle.image} alt="Thumbnail 1" class="h-full w-full object-cover" />
            </button>
            <button class="thumbnail shrink-0 h-20 w-20 overflow-hidden rounded-lg border-2 border-transparent transition hover:border-fvplata-300" data-index="1">
              <img src={vehicle.image} alt="Thumbnail 2" class="h-full w-full object-cover" />
            </button>
            <button class="thumbnail shrink-0 h-20 w-20 overflow-hidden rounded-lg border-2 border-transparent transition hover:border-fvplata-300" data-index="2">
              <img src={vehicle.image} alt="Thumbnail 3" class="h-full w-full object-cover" />
            </button>
            <button class="thumbnail shrink-0 h-20 w-20 overflow-hidden rounded-lg border-2 border-transparent transition hover:border-fvplata-300" data-index="3">
              <img src={vehicle.image} alt="Thumbnail 4" class="h-full w-full object-cover" />
            </button>
          </div>

          <div class="grid grid-cols-1 gap-3 sm:grid-cols-3 sm:gap-4 lg:gap-5">
            <div class="rounded-2xl border border-fvplata-300/15 bg-fvantracita-900/80 p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur-sm">
              <p class="text-[0.65rem] font-overpass uppercase tracking-[0.28em] text-fvplata-300/75">
                Libre de deudas
              </p>
              <p class="mt-2 text-sm font-bold text-white">
                Patentes al día
              </p>
            </div>

            <div class="rounded-2xl border border-fvplata-300/15 bg-fvantracita-900/80 p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur-sm">
              <p class="text-[0.65rem] font-overpass uppercase tracking-[0.28em] text-fvplata-300/75">
                Transferencia
              </p>
              <p class="mt-2 text-sm font-bold text-white">
                Obligatoria
              </p>
            </div>

            <div class="rounded-2xl border border-fvplata-300/15 bg-fvantracita-900/80 p-4 shadow-[0_0_0_1px_rgba(255,255,255,0.03)] backdrop-blur-sm">
              <p class="text-[0.65rem] font-overpass uppercase tracking-[0.28em] text-fvplata-300/75">
                Grabado
              </p>
              <p class="mt-2 text-sm font-bold text-white">
                Autopartes hecho
              </p>
            </div>
          </div>
        </div>

        <!-- Details Section -->
        <aside class="flex flex-col gap-8 lg:pt-2">
          <a href="/" class="inline-flex items-center gap-2 text-fvplata-300 transition hover:text-fvplata-100">
            <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
            Volver al inicio
          </a>

          <div class="flex flex-col gap-6">
            <div>
              <p class="mb-4 text-4xl font-bold text-fvplata-300">
                {vehicle.price}
              </p>
              <h1 class="text-5xl font-bold leading-[0.95] text-white font-primary tracking-wide sm:text-6xl xl:text-[4.5rem]">
                {vehicle.name}
              </h1>
              <div class="mt-6 flex flex-wrap gap-3">
                <VehicleBadge label="Año" value={vehicle.year} variant="glass" />
                <VehicleBadge label="Kilometraje" value={vehicle.mileage} variant="glass" />
              </div>
            </div>

            <Button href="#" text="SOLICITAR INFORMACIÓN" variant="plata" />

            <div class="bg-fvantracita-900 p-6 rounded-lg">
              <h3 class="mb-3 font-primary font-bold text-white">
                Descripción
              </h3>
              <p class="whitespace-pre-line font-overpass leading-relaxed text-fvplata-300">
                {vehicle.description}
              </p>
            </div>
          </div>
        </aside>
      </div>

      <section
        class="relative mt-12 w-full overflow-hidden px-4 py-16 sm:px-6 sm:py-20 lg:py-28"
        aria-labelledby="related-vehicles-title"
      >
        <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-fvplata-300/30 to-transparent"></div>
        <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 z-0 h-72 bg-[radial-gradient(ellipse_at_top,var(--color-fvplata-300)_0%,transparent_70%)] opacity-[0.05]"></div>

        <div class="relative mx-auto flex max-w-7xl flex-col items-center px-2 sm:px-0 2xl:max-w-352">
          <h2 id="related-vehicles-title" class="mb-3 text-center font-primary text-2xl font-bold tracking-[0.14em] text-white sm:text-4xl md:text-5xl">
            TAMBIÉN TE PODRÍA INTERESAR
          </h2>
          <p class="mb-10 max-w-xl text-center font-overpass text-[0.65rem] font-medium tracking-[0.2em] text-balance text-fvplata-300 sm:mb-16 sm:text-sm sm:tracking-[0.25em]">
            Otras unidades disponibles en inventario
          </p>
        </div>

        <div class="relative mx-auto grid max-w-7xl grid-cols-1 gap-4 sm:gap-6 md:grid-cols-2 xl:grid-cols-2 2xl:grid-cols-3 2xl:gap-8 2xl:max-w-352">
          {relatedVehicles.map((relatedVehicle) => (
            <VehicleCard
              id={relatedVehicle.id}
              image={relatedVehicle.image}
              name={relatedVehicle.name}
              price={relatedVehicle.price}
            />
          ))}
        </div>
      </section>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  const mainImage = document.getElementById('mainImage') as HTMLImageElement | null;
  const prevBtn = document.getElementById('prevBtn') as HTMLButtonElement | null;
  const nextBtn = document.getElementById('nextBtn') as HTMLButtonElement | null;
  const imageCounter = document.getElementById('imageCounter') as HTMLSpanElement | null;
  const thumbnails = document.querySelectorAll<HTMLButtonElement>('.thumbnail');

  if (!mainImage || !prevBtn || !nextBtn || !imageCounter || thumbnails.length === 0) {
    throw new Error('Vehicle gallery elements are missing');
  }

  let currentIndex = 0;
  const totalImages = thumbnails.length;

  function updateImage(index: number) {
    currentIndex = index;
    const thumbnail = thumbnails[index];
    const thumbnailImage = thumbnail.querySelector('img');

    if (!thumbnailImage) {
      return;
    }

    const imgSrc = thumbnailImage.getAttribute('src') ?? '';
    mainImage!.src = imgSrc;
    imageCounter!.textContent = String(currentIndex + 1);

    // Update thumbnail border
    thumbnails.forEach((thumb) => thumb.classList.remove('border-fvplata-300'));
    thumbnails.forEach((thumb) => thumb.classList.add('border-transparent'));
    thumbnail.classList.remove('border-transparent');
    thumbnail.classList.add('border-fvplata-300');
  }

  prevBtn.addEventListener('click', () => {
    currentIndex = (currentIndex - 1 + totalImages) % totalImages;
    updateImage(currentIndex);
  });

  nextBtn.addEventListener('click', () => {
    currentIndex = (currentIndex + 1) % totalImages;
    updateImage(currentIndex);
  });

  thumbnails.forEach((thumbnail, index) => {
    thumbnail.addEventListener('click', () => {
      updateImage(index);
    });
  });
</script>
