---
import Layout from "@/layouts/Layout.astro";
import Header from "@/sections/Header.astro";
import Hero from "@/sections/Hero.astro";
import Inventory from "@/sections/Inventory.astro";
import Brands from "@/sections/Brands.astro";
import About from "@/sections/About.astro";
import Footer from "@/sections/Footer.astro";
import Socials from "@/sections/Socials.astro";

import "@/styles/global.css";
import SellYourCar from "@/sections/SellYourCar.astro";
import Location from "@/sections/Location.astro";

const seoTitle = "Compra y Venta de Autos Usados en Adrogué - FV Automotores";
const seoDescription =
  "Comprá o vendé tu auto usado con la tranquilidad de una agencia familiar con 25 años de trayectoria en Adrogué. ¡Consultá nuestros seleccionados vía WhatsApp!";
---

<Layout title={seoTitle} description={seoDescription}>
  <Header />
  <Hero />
  <div id="showroom">
    <Inventory />
  </div>
  <Brands />
  <div id="tasacion">
  <SellYourCar />
  </div>
  <div id="nosotros">
	<About />
  </div>
  <div id="redes">
	<Socials />
  </div>
  <div id="ubicacion">
  <Location />
  </div>
  {
    /* Bloque informativo accesible (lectores de pantalla) y rastreable por motores de búsqueda. Aporta valor al contenido. */
  }
  <aside class="sr-only" aria-labelledby="dealer-details-title">
    <h2 id="dealer-details-title">Detalles del concesionario</h2>
    <p>
      Fabio Viola Automotores, con más de 25 años de experiencia, se especializa
      en la venta de autos usados en Zona Sur, Adrogué. Ofrecemos una amplia
      selección de vehículos de calidad, atención personalizada y las mejores
      opciones de financiación para ayudarte a encontrar tu próximo auto. Visita
      nuestro showroom y descubrí por qué somos la elección confiable para
      comprar tu próximo vehículo.
    </p>
  </aside>
  <Footer />
</Layout>
