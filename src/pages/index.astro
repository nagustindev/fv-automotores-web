---
import Layout from '@/layouts/Layout.astro';
import Header from '@/sections/Header.astro';
import Hero from '@/sections/Hero.astro';
import Inventory from '@/sections/Inventory.astro';
import About from '@/sections/About.astro';
import Contact from '@/sections/Contact.astro';
import Footer from '@/sections/Footer.astro';
import Socials from '@/sections/Socials.astro';

import '@/styles/global.css';

const seoTitle = 'Compra y Venta de Autos en Adrogué - Fabio Viola Automotores';
const seoDescription = 'Comprá o vendé tu auto con la tranquilidad de una agencia familiar con 25 años de trayectoria en Adrogué. ¡Consultá por nuestros seleccionados vía WhatsApp!';
---

<Layout title={seoTitle} description={seoDescription}>
	<Header />
	<Hero />
	<Inventory />
	<About />
	<Socials />
	<Contact />
	{/* Bloque informativo accesible (lectores de pantalla) y rastreable por motores de búsqueda. Aporta valor al contenido. */}
	<aside class="sr-only" aria-labelledby="dealer-details-title">
		<h2 id="dealer-details-title">Detalles del concesionario</h2>
		<p>Fabio Viola Automotores, con más de 25 años de experiencia, se especializa en la venta de autos usados en Zona Sur, Adrogué. Ofrecemos una amplia selección de vehículos de calidad, atención personalizada y las mejores opciones de financiación para ayudarte a encontrar tu próximo auto. Visita nuestro showroom y descubrí por qué somos la elección confiable para comprar tu próximo vehículo.</p>
	</aside>
	<Footer />
</Layout>



