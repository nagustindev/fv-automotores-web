---
import SocialGrid from "@/components/SocialGrid.astro";
import InstagramIcon from "@/assets/svg/instagram.svg";
import TiktokIcon from "@/assets/svg/tiktok.svg";
---

<section class="relative w-full overflow-hidden bg-[#1A1A1A] py-20 px-4">
  <div aria-hidden="true" class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-fvplata-300/30 to-transparent"></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-72 bg-[radial-gradient(ellipse_at_top,var(--color-fvplata-300)_0%,transparent_70%)] opacity-[0.05]"
  >
  </div>

  <div class="relative z-10 flex w-full flex-col items-center">
    <h2
      id="inventory-title"
      class="mb-3 text-center font-primary text-3xl font-bold tracking-[0.18em] text-white sm:text-4xl md:text-5xl"
    >
      NUESTRAS REDES
    </h2>
    <p
      class="mb-12 max-w-xl text-center font-overpass text-xs font-medium tracking-[0.25em] text-balance text-fvplata-300 sm:mb-16 sm:text-sm"
    >
      Todo lo que neccesitas saber de nuestro stock, novedades y eventos en un
      solo lugar.
    </p>

    <div class="mb-10 flex flex-col items-center gap-4 sm:mb-14 sm:flex-row sm:gap-8">
      <a
        href="https://www.instagram.com/fabioviolaautomotores/"
        data-nav-link
        target="_blank" rel="noopener noreferrer"
        aria-label="Instagram de FV Automotores"
        class="group relative inline-flex items-center gap-3 font-overpass text-sm font-semibold tracking-[0.24em] text-white transition duration-300 hover:text-fvplata-50 focus-visible:text-fvplata-50"
      >
        <InstagramIcon class="size-5 shrink-0 text-white" aria-hidden="true" />
        <span class="relative pb-1">
          /fabioviolaautomotores
          <span
            aria-hidden="true"
            data-nav-underline
            class="pointer-events-none absolute inset-x-0 -bottom-px h-px bg-fvplata-300"
          ></span>
        </span>
      </a>

      <a
        href="https://www.tiktok.com/@fabioviolaautomotores"
        data-nav-link
        target="_blank" rel="noopener noreferrer"
        aria-label="TikTok de FV Automotores"
        class="group relative inline-flex items-center gap-3 font-overpass text-sm font-semibold tracking-[0.24em] text-white transition duration-300 hover:text-fvplata-50 focus-visible:text-fvplata-50"
      >
        <TiktokIcon class="size-5 shrink-0 text-white" aria-hidden="true" />
        <span class="relative pb-1">
          /fabioviolaautomotores
          <span
            aria-hidden="true"
            data-nav-underline
            class="pointer-events-none absolute inset-x-0 -bottom-px h-px bg-fvplata-300"
          ></span>
        </span>
      </a>
    </div>

    <SocialGrid />
  </div>
</section>

<style>
  [data-nav-link] [data-nav-underline] {
    clip-path: inset(0 100% 0 0);
  }

  [data-nav-link]:hover [data-nav-underline],
  [data-nav-link]:focus-visible [data-nav-underline] {
    animation: nav-underline-open 300ms ease-out forwards;
  }

  [data-nav-link]:not(:hover):not(:focus-visible) [data-nav-underline] {
    animation: nav-underline-close 300ms ease-out forwards;
  }

  @keyframes nav-underline-open {
    from {
      clip-path: inset(0 100% 0 0);
    }

    to {
      clip-path: inset(0 0 0 0);
    }
  }

  @keyframes nav-underline-close {
    from {
      clip-path: inset(0 0 0 0);
    }

    to {
      clip-path: inset(0 0 0 100%);
    }
  }
</style>
