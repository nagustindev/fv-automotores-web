---
import TiktokBrandIcon from "@/assets/svg/tiktok.svg";
import InstagramBrandIcon from "@/assets/svg/instagram.svg";
import Button from "@/components/Button.astro";
import WhatsAppIcon from "@/assets/svg/whatsapp.svg";

const NAV_ITEMS = [
  {
    label: "Showroom",
    href: "#showroom",
  },
  {
    label: "Tasación",
    href: "#tasacion",
  },
  {
    label: "Nosotros",
    href: "#nosotros",
  },
  {
    label: "Redes",
    href: "#redes",
  },
  {
    label: "Ubicación",
    href: "#ubicacion",
  },
] as const;

const whatsappNumber = "5491144441290";
const defaultMessage =
  "Hola! Vi la página web de FV Automotores y quería consultar por los vehículos en stock.";

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;

const PLATFORMS = {
  marketplace: "https://www.facebook.com/marketplace/profile/100012851116368",
  mercadolibre: "https://vehiculos.mercadolibre.com.ar/_CustId_129556687",
};
---

<footer class="relative w-full overflow-hidden bg-primary">
  <picture class="absolute inset-0">
    <source type="image/webp" srcset="/footer_background.webp 1x" />
    <img
      src="/footer_background.webp"
      alt=""
      role="presentation"
      class="h-full w-full object-cover object-center"
      fetchpriority="high"
      decoding="async"
    />
  </picture>
  
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-fvplata-300/30 to-transparent z-10"
  >
  </div>
  
  <div
    class="pointer-events-none absolute inset-0 bg-linear-to-b from-black/15 via-black/30 to-primary/85"
    aria-hidden="true"
  >
  </div>
  
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 z-0 h-40 bg-[radial-gradient(ellipse_at_top,var(--color-fvplata-300)_0%,transparent_70%)] opacity-[0.05]"
  >
  </div>

  <header
    class="relative z-20 flex w-full flex-col items-start justify-center px-4 py-20 text-left sm:px-6 sm:py-28 lg:px-8 lg:py-32"
  >
    <h2
      class="text-balance font-primary text-3xl font-bold tracking-[0.18em] text-white sm:text-4xl lg:text-6xl"
    >
      EL SHOWROOM ESTÁ ABIERTO PARA VOS
    </h2>
    <h3
      class="mt-4 max-w-2xl text-balance font-overpass text-base text-fvplata-300 sm:text-xl lg:text-2xl"
    >
      Vení a conocernos, tomá un café y mirá nuestro stock con total
      tranquilidad. Te ofrecemos un espacio transparente y sin presiones para
      elegir tu próximo vehículo.
    </h3>
    <Button
      data-hero-cta="primary"
      href={whatsappUrl}
      target="_blank"
      rel="noopener noreferrer"
      text="CONSULTAR"
      icon={WhatsAppIcon}
      iconClass="size-6"
      variant="plata"
      class="mt-6"
    />
  </header>
</footer>

<footer
  class="relative w-full bg-fvantracita-950 px-4 pb-0 pt-20 sm:px-6 lg:pt-28 lg:pb-0 lg:px-8 border-t border-fvantracita-900"
>
  <div class="mx-auto max-w-7xl">
    <div class="grid grid-cols-2 gap-8 md:grid-cols-4 lg:gap-12">
      
      <div>
        <h4 class="mb-5 font-primary text-xs font-bold tracking-[0.2em] text-white uppercase opacity-90">
          Navegación
        </h4>
        <ul class="space-y-3.5">
          {
            NAV_ITEMS.map((item) => (
              <li>
                <a
                  href={item.href}
                  data-nav-link
                  class="group relative inline-flex items-center font-overpass text-sm text-fvantracita-400 transition duration-300 hover:text-white focus-visible:text-white outline-none"
                >
                  <span class="relative inline-block">
                    <span
                      aria-hidden="true"
                      data-nav-underline
                      class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                    />
                    {item.label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-primary text-xs font-bold tracking-[0.2em] text-white uppercase opacity-90">
          Stock Activo
        </h4>
        <ul class="space-y-3.5">
          <li>
            <a
              href={PLATFORMS.mercadolibre}
              target="_blank"
              rel="noopener noreferrer"
              data-nav-link
              class="group relative inline-flex items-center font-overpass text-sm text-fvantracita-400 transition duration-300 hover:text-white focus-visible:text-white outline-none"
            >
              <span class="relative inline-block">
                <span
                  aria-hidden="true"
                  data-nav-underline
                  class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                />
                Mercado Libre
              </span>
            </a>
          </li>
          <li>
            <a
              href={PLATFORMS.marketplace}
              target="_blank"
              rel="noopener noreferrer"
              data-nav-link
              class="group relative inline-flex items-center font-overpass text-sm text-fvantracita-400 transition duration-300 hover:text-white focus-visible:text-white outline-none"
            >
              <span class="relative inline-block">
                <span
                  aria-hidden="true"
                  data-nav-underline
                  class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                />
                FB Marketplace
              </span>
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-primary text-xs font-bold tracking-[0.2em] text-white uppercase opacity-90">
          Contacto
        </h4>
        <ul class="space-y-3.5">
          <li>
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              data-nav-link
              class="group relative inline-flex items-center font-overpass text-sm text-fvantracita-400 transition duration-300 hover:text-white focus-visible:text-white outline-none"
            >
              <span class="relative inline-block">
                <span
                  aria-hidden="true"
                  data-nav-underline
                  class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                />
                WhatsApp - Juampi
              </span>
            </a>
          </li>
          <li>
            <a
              href="https://maps.app.goo.gl/47jRbT5xKREkKUKAA"
              target="_blank"
              rel="noopener noreferrer"
              data-nav-link
              class="group relative inline-flex items-center font-overpass text-sm leading-relaxed text-fvantracita-400 transition duration-300 hover:text-white focus-visible:text-white outline-none max-w-[26ch]"
            >
              <span class="relative inline-block">
                <span
                  aria-hidden="true"
                  data-nav-underline
                  class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                />
                Ceferino Ramírez 1079, B1846 Adrogué, Buenos Aires
              </span>
            </a>
          </li>
        </ul>
      </div>

      <div>
        <h4 class="mb-5 font-primary text-xs font-bold tracking-[0.2em] text-white uppercase opacity-90">
          Redes
        </h4>
        <div class="flex gap-4">
          <a
            href="https://www.instagram.com/fabioviolaautomotores/"
            aria-label="Seguir a FV Automotores en Instagram"
            target="_blank"
            rel="noopener noreferrer"
            class="transition duration-300 text-fvantracita-400 hover:text-white focus-visible:text-white"
          >
            <InstagramBrandIcon class="size-6 currentColor" />
          </a>
          <a
            href="https://www.tiktok.com/@fabioviolaautomotores"
            aria-label="Seguir a FV Automotores en TikTok"
            target="_blank"
            rel="noopener noreferrer"
            class="transition duration-300 text-fvantracita-400 hover:text-white focus-visible:text-white"
          >
            <TiktokBrandIcon class="size-6 currentColor" />
          </a>
        </div>
      </div>
    </div>

    <div
      class="my-8 h-px bg-linear-to-r from-transparent via-fvantracita-800 to-transparent"
    >
    </div>
    
    <p class="mb-3 text-left text-xs text-fvantracita-400 font-overpass font-medium">
      © {new Date().getFullYear()} FV Automotores. Todos los derechos reservados.
    </p>
    
    <div class="max-w-5xl text-left font-overpass text-[11px] leading-relaxed text-fvantracita-500 font-light pb-4">
      <p>
        <strong>FV Automotores</strong> es una concesionaria de autos usados seleccionados
        y vehículos utilitarios ubicada en <strong>Adrogué</strong>. Ofrecemos
        asesoramiento y comercialización de unidades con un estricto estándar de
        calidad y documentación garantizada, con zona de influencia en Adrogué,
        Lomas de Zamora, Llavallol y todo <strong>Zona Sur</strong> del Gran Buenos
        Aires.
      </p>
    </div>
  </div>

  <div
    id="fv-interactive-logo"
    class="relative mt-6 overflow-hidden select-none pointer-events-auto w-full max-w-[120%] fade-right translate-x-[-2%]"
  >
    <div class="z-0 opacity-10 mix-blend-soft-light transition-opacity duration-500">
      <img
        src="/logo-footer.svg"
        alt=""
        aria-hidden="true"
        class="w-full h-auto object-left object-contain brightness-50 contrast-125"
      />
    </div>

    <div
      id="fv-revealed-layer"
      class="absolute inset-0 z-10 opacity-0"
      style="mask-image: radial-gradient(circle 260px at calc(var(--mouse-x, 0) * 1px) calc(var(--mouse-y, 0) * 1px), rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.65) 45%, rgba(0,0,0,0.3) 75%, transparent 100%); -webkit-mask-image: radial-gradient(circle 260px at calc(var(--mouse-x, 0) * 1px) calc(var(--mouse-y, 0) * 1px), rgba(0,0,0,0.9) 0%, rgba(0,0,0,0.65) 45%, rgba(0,0,0,0.3) 75%, transparent 100%);"
    >
      <img
        src="/logo-footer.svg"
        alt=""
        aria-hidden="true"
        class="w-full h-auto object-left object-contain brightness-110"
      />
    </div>

    <div aria-hidden="true" class="pointer-events-none absolute inset-0 z-20 fv-logo-grain"></div>
  </div>
</footer>

<style>
  picture {
    -webkit-mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 75%,
      rgba(0, 0, 0, 0.4) 88%,
      transparent 100%
    );
    mask-image: linear-gradient(
      to bottom,
      #000 0%,
      #000 75%,
      rgba(0, 0, 0, 0.4) 88%,
      transparent 100%
    );
  }

  img {
    transform: scale(var(--hero-bg-scale, 1));
    transform-origin: center center;
    will-change: transform;
  }

  @media (prefers-reduced-motion: reduce) {
    img {
      transform: none;
    }
  }

  .fade-right {
    opacity: 0.18;
    -webkit-mask-image: linear-gradient(
      to right,
      #000 0%,
      #000 55%,
      transparent 100%
    );
    mask-image: linear-gradient(to right, #000 0%, #000 55%, transparent 100%);
  }

  #fv-revealed-layer {
    mask-repeat: no-repeat;
    -webkit-mask-repeat: no-repeat;
  }

  .fv-logo-grain {
    opacity: 0.12;
    mix-blend-mode: soft-light;
    background-image:
      radial-gradient(rgba(255, 255, 255, 0.2) 0.5px, transparent 0.7px),
      radial-gradient(rgba(255, 255, 255, 0.15) 0.5px, transparent 0.7px);
    background-size: 2px 2px, 3px 3px;
    background-position: 0 0, 1px 1px;
    filter: contrast(120%);
  }
</style>

<script>
  import { gsap } from "gsap";

  let cleanupListeners: (() => void) | null = null;
  const SPOTLIGHT_ACTIVATION_PADDING = 320;

  function setupNavLinks() {
    const links = document.querySelectorAll("[data-nav-link]");

    links.forEach((link) => {
      const underline = link.querySelector("[data-nav-underline]");
      if (!underline) return;

      gsap.set(underline, { clipPath: "inset(0 100% 0 0)" });

      link.addEventListener("pointerenter", () => {
        gsap.killTweensOf(underline);
        gsap.to(underline, {
          clipPath: "inset(0 0% 0 0)",
          duration: 0.32,
          ease: "power2.out",
        });
      });

      link.addEventListener("pointerleave", () => {
        gsap.killTweensOf(underline);
        gsap.to(underline, {
          clipPath: "inset(0 0% 0 100%)",
          duration: 0.32,
          ease: "power2.inOut",
          onComplete: () => {
            gsap.set(underline, { clipPath: "inset(0 100% 0 0)" });
          },
        });
      });
    });
  }

  function setupInteractiveLogo(): (() => void) | null {
    const container = document.getElementById("fv-interactive-logo");
    const revealedLayer = document.getElementById("fv-revealed-layer");

    if (!container || !revealedLayer) return null;

    let rect = container.getBoundingClientRect();

    const cacheRect = () => {
      rect = container.getBoundingClientRect();
    };

    window.addEventListener("resize", cacheRect, { passive: true });
    window.addEventListener("scroll", cacheRect, { passive: true });

    const xTo = gsap.quickTo(revealedLayer, "--mouse-x", { duration: 0.35, ease: "power2.out" });
    const yTo = gsap.quickTo(revealedLayer, "--mouse-y", { duration: 0.35, ease: "power2.out" });
    const opacityTo = gsap.quickTo(revealedLayer, "opacity", { duration: 0.28, ease: "power1.out" });

    const updateSpotlight = (clientX: number, clientY: number) => {
      const dx = Math.max(rect.left - clientX, 0, clientX - rect.right);
      const dy = Math.max(rect.top - clientY, 0, clientY - rect.bottom);
      const distance = Math.hypot(dx, dy);
      const normalized = Math.max(0, 1 - distance / SPOTLIGHT_ACTIVATION_PADDING);
      const opacity = Math.min(0.8, normalized * 0.8);

      if (opacity <= 0) {
        opacityTo(0);
        return;
      }

      opacityTo(opacity);

      const x = Math.min(Math.max(clientX - rect.left, 0), rect.width);
      const y = Math.min(Math.max(clientY - rect.top, 0), rect.height);

      xTo(x);
      yTo(y);
    };

    const handlePointerMove = (e: PointerEvent) => {
      if (e.pointerType === "touch") return;
      updateSpotlight(e.clientX, e.clientY);
    };

    const handlePointerLeave = () => {
      opacityTo(0);
    };

    window.addEventListener("pointermove", handlePointerMove, { passive: true });
    window.addEventListener("pointerleave", handlePointerLeave, { passive: true });

    return () => {
      window.removeEventListener("resize", cacheRect);
      window.removeEventListener("scroll", cacheRect);
      window.removeEventListener("pointermove", handlePointerMove);
      window.removeEventListener("pointerleave", handlePointerLeave);
    };
  }

  document.addEventListener("astro:page-load", () => {
    setupNavLinks();
    if (cleanupListeners) cleanupListeners();
    cleanupListeners = setupInteractiveLogo();
  });
</script>