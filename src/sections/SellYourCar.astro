---
import Button from "@/components/Button.astro";
import WhatsAppIcon from "@/assets/svg/whatsapp.svg";
import SectionHeader from "@/components/SectionHeader.astro";
import SectionGlowDivider from "@/components/SectionGlowDivider.astro";

const whatsappNumber = "5491144441290";
const defaultMessage =
  "Hola, buenas tardes. Me contactaba desde la página web de FV Automotores para coordinar una tasación de mi vehículo usado. Quedo atento a su respuesta.";

const whatsappUrl = `https://wa.me/${whatsappNumber}?text=${encodeURIComponent(defaultMessage)}`;
---

<section
  class="relative w-full overflow-hidden bg-primary py-24 sm:py-32"
  aria-labelledby="selling-title"
>
  <picture class="absolute inset-0 z-0" aria-hidden="true">
    <source type="image/webp" srcset="/we_buy_your_usedcar.webp 1x" />
    <img
      src="/we_buy_your_usedcar.webp"
      alt=""
      role="presentation"
      class="h-full w-full object-cover object-center"
      decoding="async"
    />
  </picture>

  <div
    class="absolute inset-0 z-1 bg-linear-to-b from-primary via-black/40 to-primary"
    aria-hidden="true"
  >
  </div>
  <SectionGlowDivider />
  <div class="relative z-10 mx-auto flex max-w-6xl flex-col items-center px-4">
    <SectionHeader
      hideDivider={true}
      titleId="selling-title"
      eyebrow="FABIO VIOLA AUTOMOTORES"
      title="¿PENSÁS VENDER TU AUTO?"
      subtitle="Compartí con nosotros los detalles de tu vehículo y te ofrecemos una tasación inmediata y transparente."
    />
  </div>

  <div
    class="relative z-10 mx-auto flex w-full max-w-7xl flex-col items-center"
  >
    <div class="flex justify-center mb-20">
      <Button
        data-hero-cta="primary"
        href={whatsappUrl}
        target="_blank"
        rel="noopener noreferrer"
        text="CONSULTAR"
        icon={WhatsAppIcon}
        iconClass="size-6"
        variant="plata"
      />
    </div>

    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-6 w-full max-w-5xl mx-auto px-4 sm:px-0"
    >
      <div
        class="group rounded-2xl border border-fvantracita-900/60 bg-fvantracita-950/75 p-6 shadow-2xl backdrop-blur-md transition-all duration-400 hover:border-fvantracita-700 hover:bg-fvantracita-950/90"
      >
        <span
          class="block font-primary text-xl font-black text-fvplata-400 mb-2 group-hover:text-white transition-colors duration-400"
          >01</span
        >
        <h3
          class="font-primary text-sm font-bold text-white uppercase tracking-wider mb-2"
        >
          Compartí Info
        </h3>
        <p
          class="font-overpass text-xs font-light leading-relaxed text-fvantracita-400"
        >
          Pasanos el modelo, año y kilometraje real de tu unidad directamente
          por nuestro WhatsApp.
        </p>
      </div>

      <div
        class="group rounded-2xl border border-fvantracita-900/60 bg-fvantracita-950/75 p-6 shadow-2xl backdrop-blur-md transition-all duration-400 hover:border-fvantracita-700 hover:bg-fvantracita-950/90"
      >
        <span
          class="block font-primary text-xl font-black text-fvplata-400 mb-2 group-hover:text-white transition-colors duration-400"
          >02</span
        >
        <h3
          class="font-primary text-sm font-bold text-white uppercase tracking-wider mb-2"
        >
          Recibí la Oferta
        </h3>
        <p
          class="font-overpass text-xs font-light leading-relaxed text-fvantracita-400"
        >
          Evaluamos los parámetros de mercado en Zona Sur y te enviamos una
          cotización preliminar transparente y competitiva.
        </p>
      </div>

      <div
        class="group rounded-2xl border border-fvantracita-900/60 bg-fvantracita-950/75 p-6 shadow-2xl backdrop-blur-md transition-all duration-400 hover:border-fvantracita-700 hover:bg-fvantracita-950/90"
      >
        <span
          class="block font-primary text-xl font-black text-fvplata-400 mb-2 group-hover:text-white transition-colors duration-400"
          >03</span
        >
        <h3
          class="font-primary text-sm font-bold text-white uppercase tracking-wider mb-2"
        >
          Cerrá el Trato
        </h3>
        <p
          class="font-overpass text-xs font-light leading-relaxed text-fvantracita-400"
        >
          Traés el coche al showroom de Adrogué, verificamos el estado general y
          te llevás el efectivo de forma segura e inmediata.
        </p>
      </div>
    </div>
  </div>
</section>
