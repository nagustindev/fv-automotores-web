---
const HITOS = [
  {
    year: "2001",
    title: "Sentando las Bases",
    description: "Comenzamos en Zona Sur con una premisa simple pero innegociable: seleccionar únicamente autos usados particulares cuyo estado fuera demostrable y transparente.",
    img: "/hito-2001.webp"
  },
  {
    year: "2012",
    title: "Enfoque Utilitario",
    description: "Identificamos la necesidad de vehículos de trabajo fiables en la región. Especializamos nuestro catálogo en camionetas y utilitarios preparados bajo un estándar clínico.",
    img: "/hito-2012.webp"
  },
  {
    year: "2020",
    title: "El Showroom de Adrogué",
    description: "Consolidamos nuestro cuartel general en Ceferino Ramírez. Un espacio diseñado para atenderte cara a cara, tomar un café y revisar la documentación sin presiones.",
    img: "/hito-2020.webp"
  },
  {
    year: "Presente",
    title: "Estándar Garantizado",
    description: "Hoy, Fabio y Juan Pablo seguimos al frente de cada ingreso. Manteniendo el mismo criterio estricto de gestoría legal y mecánica que nos dio vigencia por un cuarto de siglo.",
    img: "/hito-presente.webp"
  }
] as const;

import AboutLayerLayering from "@/components/AboutLayerLayering.astro";
---

<section>
  <AboutLayerLayering />


<section class="w-full py-20 px-4 sm:px-6 lg:px-8 overflow-hidden">
  <div class="mx-auto max-w-7xl">
    
    <div data-hitos-wrapper class="relative w-full overflow-hidden cursor-grab active:cursor-grabbing">
      <div data-hitos-slider class="flex gap-6 sm:gap-8 w-max will-change-transform">
        {
          HITOS.map((hito, index) => (
            <div 
              data-hito-card 
              data-index={index}
              class="w-[82vw] sm:w-[55vw] lg:w-[45vw] shrink-0 flex flex-col space-y-6"
            >
              <div class="aspect-16/10 w-full overflow-hidden bg-fvantracita-950 border border-fvantracita-900 rounded-sm">
                <img 
                  src={hito.img} 
                  alt={`${hito.title} - FV Automotores`}
                  class="h-full w-full object-cover object-center grayscale contrast-125 brightness-90 transition-transform duration-500 hover:scale-102"
                  loading="lazy"
                  decoding="async"
                />
              </div>

              <div class="space-y-2 text-left">
                <h3 class="font-primary text-sm font-bold tracking-wider text-white sm:text-base">
                  {hito.year} – {hito.title}.
                </h3>
                <p class="max-w-xl font-overpass text-xs font-light leading-relaxed text-fvantracita-400 sm:text-sm">
                  {hito.description}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </div>

    <div class="mt-10 flex items-center justify-start gap-2 pl-1">
      {
        HITOS.map((_, index) => (
          <button
            type="button"
            data-hito-dot={index}
            class="size-1.5 rounded-full bg-fvantracita-700 transition-all duration-300 data-[active=true]:bg-white data-[active=true]:scale-125"
            aria-label={`Ir al hito ${index + 1}`}
          />
        ))
      }
    </div>

  </div>
</section>

<script>
  import { gsap } from "gsap";
  import { Draggable } from "gsap/Draggable";

  gsap.registerPlugin(Draggable);

  function setupHitosSlider() {
    const wrapper = document.querySelector("[data-hitos-wrapper]");
    const slider = document.querySelector("[data-hitos-slider]");
    const dots = document.querySelectorAll("[data-hito-dot]");
    const cards = document.querySelectorAll("[data-hito-card]");

    if (!wrapper || !slider || dots.length === 0 || cards.length === 0) return;

    dots[0].setAttribute("data-active", "true");

    const updateBounds = () => {
      const wrapperWidth = (wrapper as HTMLElement).offsetWidth;
      const sliderWidth = (slider as HTMLElement).offsetWidth;
      return Math.min(0, wrapperWidth - sliderWidth);
    };

    Draggable.create(slider, {
      type: "x",
      edgeResistance: 0.85,
      bounds: { minX: updateBounds(), maxX: 0 },
      inertia: true,
      throwProps: true,
      onDrag: updateActiveDot,
      onThrowUpdate: updateActiveDot,
      snap: {
        x: function(endValue) {
          const cardWidth = (cards[0] as HTMLElement).offsetWidth + 32; 
          return Math.round(endValue / cardWidth) * cardWidth;
        }
      }
    });

    function updateActiveDot() {
      const xPos = gsap.getProperty(slider, "x") as number;
      const cardWidth = (cards[0] as HTMLElement).offsetWidth + 32;
      const activeIndex = Math.min(
        dots.length - 1,
        Math.max(0, Math.round(Math.abs(xPos) / cardWidth))
      );

      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.setAttribute("data-active", "true");
        } else {
          dot.removeAttribute("data-active");
        }
      });
    }

    dots.forEach((dot, index) => {
      dot.addEventListener("click", () => {
        const cardWidth = (cards[0] as HTMLElement).offsetWidth + 32;
        const targetX = Math.max(updateBounds(), -(index * cardWidth));

        gsap.to(slider, {
          x: targetX,
          duration: 0.5,
          ease: "power2.out",
          onComplete: updateActiveDot
        });
      });
    });

    window.addEventListener("resize", () => {
      const dragInstance = Draggable.get(slider);
      if (dragInstance) {
        dragInstance.applyBounds({ minX: updateBounds(), maxX: 0 });
      }
    }, { passive: true });
  }

  document.addEventListener("astro:page-load", setupHitosSlider);
</script>
</section>
