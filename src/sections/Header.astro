---
const NAV_ITEMS = [
    {
        label: "Ingresos",
        href: "/ingresos",
    },
    {
        label: "Nosotros",
        href: "/nosotros",
    },
    {
        label: "Contacto",
        href: "/contacto",
    },
] as const;

const currentPath = Astro.url.pathname;

const shouldReloadNavItem = (href: string) => currentPath === "/" && href === "/nosotros";
---
<header
    data-header
    data-menu-open="false"
    class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent backdrop-blur-[0px] transition-[background-color,backdrop-filter,border-color] duration-500 ease-out data-[scrolled=true]:border-white/5 data-[scrolled=true]:bg-fvazul-950/40 data-[scrolled=true]:backdrop-blur-md"
>
    <div class="relative z-50 mx-auto grid max-w-7xl grid-cols-[auto_1fr_auto] items-center gap-4 px-4 py-3 sm:px-6 sm:py-4">
        <a
            href="/"
            class="group flex items-center gap-3 outline-none focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent"
            aria-label="FV Automotores - Inicio"
        >
            <img
                src="/logo.svg"
                alt=""
                class="h-7 w-auto transition duration-500 group-hover:-rotate-2 sm:h-10"
                width="30"
                height="30"
                decoding="async"
            />
        </a>

        <nav class="hidden justify-self-center md:block" aria-label="Navegación principal">
            <ul class="flex items-center gap-1 sm:gap-2">
                {
                    NAV_ITEMS.map((item) => (
                        <li>
                            <a
                                href={item.href}
                                data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                                data-nav-link
                                class="group relative inline-flex items-center px-3 py-2 font-display text-[0.65rem] font-bold tracking-[0.25em] text-white/85 transition duration-300 outline-none hover:text-fvplata-50 focus-visible:text-fvplata-50 sm:px-4 sm:text-xs"
                            >
                                <span
                                    aria-hidden="true"
                                    data-nav-underline
                                    class="pointer-events-none absolute inset-x-3 -bottom-px h-px bg-fvazul-100 sm:inset-x-4"
                                />
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>

        <button
            type="button"
            data-mobile-menu-button
            class="group relative col-start-3 inline-flex h-11 w-11 items-center justify-center justify-self-end   text-fvplata-50 outline-none transition duration-300 focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent md:hidden"
            aria-controls="mobile-menu"
            aria-expanded="false"
            aria-label="Abrir menú"
        >
            <span class="sr-only">Abrir menú</span>
            <span
                aria-hidden="true"
                class="absolute h-px w-5 -translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:rotate-45"
            ></span>
            <span
                aria-hidden="true"
                class="absolute h-px w-5 bg-current transition duration-300 group-data-[open=true]:opacity-0"
            ></span>
            <span
                aria-hidden="true"
                class="absolute h-px w-5 translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:-rotate-45"
            ></span>
        </button>
    </div>

    <div
        id="mobile-menu"
        data-mobile-menu
        aria-hidden="true"
        inert
        class="fixed inset-0 z-40 flex min-h-dvh -translate-y-2 items-center justify-center overflow-y-auto bg-black/95 px-6 py-28 opacity-0 backdrop-blur-2xl transition duration-300 ease-out pointer-events-none data-[open=true]:translate-y-0 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto md:hidden"
    >
        <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-[radial-gradient(circle_at_50%_0%,rgba(30,139,255,0.18),transparent_62%)]"
        ></div>
        <nav aria-label="Menú principal móvil" class="relative w-full max-w-sm">
            <ul class="flex flex-col items-center gap-6">
                {
                    NAV_ITEMS.map((item) => (
                        <li class="w-full">
                            <a
                                href={item.href}
                                data-astro-reload={shouldReloadNavItem(item.href) ? true : undefined}
                                data-mobile-menu-link
                                    data-nav-link
                                class="group relative flex items-center justify-center rounded-2xl border border-fvazul-200/35 bg-fvazul-500/10 px-5 py-5 text-center font-display text-lg font-bold tracking-[0.28em] text-fvplata-50 outline-none transition duration-300 hover:border-fvazul-300 hover:bg-fvazul-500/20 focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent"
                            >
                                <span
                                    aria-hidden="true"
                                        data-nav-underline
                                        class="pointer-events-none absolute inset-x-6 bottom-3 h-px bg-fvazul-500"
                                />
                                {item.label}
                            </a>
                        </li>
                    ))
                }
            </ul>
        </nav>
    </div>
</header>

<style>
    [data-nav-link] [data-nav-underline] {
        clip-path: inset(0 100% 0 0);
    }

    [data-nav-link]:hover [data-nav-underline],
    [data-nav-link]:focus-visible [data-nav-underline],
    [data-nav-link][data-underline-state="opening"] [data-nav-underline] {
        animation: nav-underline-open 300ms ease-out forwards;
    }

    [data-nav-link][data-underline-state="closing"] [data-nav-underline] {
        animation: nav-underline-close 300ms ease-out forwards;
    }

    @keyframes nav-underline-open {
        from {
            clip-path: inset(0 100% 0 0);
        }

        to {
            clip-path: inset(0 0 0 0);
        }
    }

    @keyframes nav-underline-close {
        from {
            clip-path: inset(0 0 0 0);
        }

        to {
            clip-path: inset(0 0 0 100%);
        }
    }
</style>

<script>
    const SCROLL_THRESHOLD = 24;
    const UNDERLINE_DURATION = 300;

    let scrollAbortController: AbortController | null = null;
    let menuAbortController: AbortController | null = null;
    let navUnderlineAbortController: AbortController | null = null;

    function setupHeaderScroll() {
        const header = document.querySelector('[data-header]');
        if (!header) return;

        scrollAbortController?.abort();
        scrollAbortController = new AbortController();

        const update = () => {
            const scrolled = window.scrollY > SCROLL_THRESHOLD;
            if (scrolled) {
                header.setAttribute('data-scrolled', 'true');
            } else {
                header.removeAttribute('data-scrolled');
            }
        };

        update();

        window.addEventListener('scroll', update, {
            passive: true,
            signal: scrollAbortController.signal,
        });
    }

    function setupMobileMenu() {
        const header = document.querySelector('[data-header]') as HTMLElement | null;
        const menu = document.querySelector('[data-mobile-menu]') as HTMLElement | null;
        const button = document.querySelector('[data-mobile-menu-button]') as HTMLButtonElement | null;
        const links = Array.from(document.querySelectorAll('[data-mobile-menu-link]')) as HTMLAnchorElement[];

        if (!header || !menu || !button) return;

        menuAbortController?.abort();
        menuAbortController = new AbortController();
        const { signal } = menuAbortController;

        const setMenuOpen = (isOpen: boolean) => {
            header.setAttribute('data-menu-open', String(isOpen));
            menu.setAttribute('data-open', String(isOpen));
            button.setAttribute('data-open', String(isOpen));
            menu.setAttribute('aria-hidden', String(!isOpen));
            menu.inert = !isOpen;
            button.setAttribute('aria-expanded', String(isOpen));
            button.setAttribute('aria-label', isOpen ? 'Cerrar menú' : 'Abrir menú');

            const label = button.querySelector('.sr-only');
            if (label) label.textContent = isOpen ? 'Cerrar menú' : 'Abrir menú';

            document.documentElement.classList.toggle('overflow-hidden', isOpen);
        };

        setMenuOpen(false);

        button.addEventListener(
            'click',
            () => {
                setMenuOpen(button.getAttribute('aria-expanded') !== 'true');
            },
            { signal }
        );

        links.forEach((link) => {
            link.addEventListener(
                'click',
                () => {
                    setMenuOpen(false);
                },
                { signal }
            );
        });

        window.addEventListener(
            'keydown',
            (event) => {
                if (event.key === 'Escape') setMenuOpen(false);
            },
            { signal }
        );
    }

    function setupNavUnderline() {
        const links = Array.from(document.querySelectorAll('[data-nav-link]')) as HTMLAnchorElement[];

        navUnderlineAbortController?.abort();
        navUnderlineAbortController = new AbortController();
        const { signal } = navUnderlineAbortController;

        links.forEach((link) => {
            let closeTimer: number | undefined;

            link.addEventListener(
                'pointerenter',
                () => {
                    window.clearTimeout(closeTimer);
                    link.dataset.underlineState = 'opening';
                },
                { signal }
            );

            link.addEventListener(
                'pointerleave',
                () => {
                    link.dataset.underlineState = 'closing';
                    closeTimer = window.setTimeout(() => {
                        delete link.dataset.underlineState;
                    }, UNDERLINE_DURATION);
                },
                { signal }
            );
        });
    }

    document.addEventListener('astro:page-load', () => {
        setupHeaderScroll();
        setupMobileMenu();
        setupNavUnderline();
    });
</script>