---
const NAV_ITEMS = [
  {
    label: "Showroom",
    href: "#showroom",
  },
  {
    label: "Tasación",
    href: "#tasacion", 
  },
  {
    label: "Nosotros",
    href: "#nosotros", 
  },
  {
    label: "Redes",
    href: "#redes", 
  },
  {
    label: "Ubicación",
    href: "#ubicacion", 
  },
] as const;
---

<header
  data-header
  data-menu-open="false"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent bg-transparent backdrop-blur-[0px] transition-[background-color,backdrop-filter,border-color] duration-500 ease-out data-[scrolled=true]:border-fv-antracita-700/5 data-[scrolled=true]:bg-primary/40 data-[scrolled=true]:backdrop-blur-md"
>
  <div
    class="relative z-50 mx-auto grid max-w-7xl grid-cols-[auto_1fr_auto] items-center gap-4 px-4 py-3 sm:px-6 sm:py-4"
  >
    <a
      href="/"
      data-nav-link
      class="group flex items-center gap-3 outline-none focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent"
      aria-label="FV Automotores - Inicio"
    >
      <span
        data-logo-reveal
        class="group/logo relative flex h-7 w-36 items-center justify-center sm:h-10 sm:w-52"
        aria-hidden="true"
      >
        <img
          data-logo-base
          src="/logo.svg"
          alt=""
          class="absolute inset-0 h-full w-full object-contain"
          width="30"
          height="30"
          decoding="async"
        />
        <img
          data-logo-chrome
          src="/logo-cromado.svg"
          alt=""
          class="absolute inset-0 h-full w-full object-contain opacity-0"
          width="30"
          height="30"
          decoding="async"
        />
        <img
          data-logo-anniversary
          src="/25anios.svg"
          alt=""
          class="absolute inset-0 h-full w-full object-contain opacity-0"
          width="30"
          height="30"
          decoding="async"
        />
      </span>
    </a>

    <nav
      class="hidden justify-self-center md:block"
      aria-label="Navegación principal"
    >
      <ul class="flex items-center gap-1 sm:gap-2">
        {
          NAV_ITEMS.map((item) => (
            <li>
              <a
                href={item.href}
                data-nav-link
                class="group relative inline-flex items-center px-3 py-2 font-primary text-[0.65rem] font-bold tracking-[0.25em] text-white/85 transition duration-300 outline-none hover:text-fvplata-50 focus-visible:text-fvplata-50 sm:px-4 sm:text-xs"
              >
                <span class="relative inline-block">
                  <span
                    aria-hidden="true"
                    data-nav-underline
                    class="pointer-events-none absolute inset-x-0 -bottom-1 h-px bg-fvplata-300"
                  />
                  {item.label}
                </span>
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <button
      type="button"
      data-mobile-menu-button
      class="group relative col-start-3 inline-flex h-11 w-11 items-center justify-center justify-self-end text-fvplata-50 outline-none transition duration-300 focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent md:hidden"
      aria-controls="mobile-menu"
      aria-expanded="false"
      aria-label="Abrir menú"
    >
      <span class="sr-only">Abrir menú</span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 -translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:rotate-45"
      ></span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 bg-current transition duration-300 group-data-[open=true]:opacity-0"
      ></span>
      <span
        aria-hidden="true"
        class="absolute h-px w-5 translate-y-1.5 bg-current transition duration-300 group-data-[open=true]:translate-y-0 group-data-[open=true]:-rotate-45"
      ></span>
    </button>
  </div>

  <div
    id="mobile-menu"
    data-mobile-menu
    aria-hidden="true"
    inert
    class="fixed inset-0 z-40 flex min-h-dvh -translate-y-2 items-center justify-center overflow-y-auto bg-black/95 px-6 py-28 opacity-0 backdrop-blur-2xl transition duration-300 ease-out pointer-events-none data-[open=true]:translate-y-0 data-[open=true]:opacity-100 data-[open=true]:pointer-events-auto md:hidden"
  >
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 top-0 h-64 bg-[radial-gradient(circle_at_50%_0%,rgba(30,139,255,0.18),transparent_62%)]"
    >
    </div>
    <nav aria-label="Menú principal mobile" class="relative w-full max-w-sm">
      <ul class="flex flex-col items-center gap-6">
        {
          NAV_ITEMS.map((item) => (
            <li class="w-full">
              <a
                href={item.href}
                data-mobile-menu-link
                data-nav-link
                class="group relative flex items-center justify-center rounded-2xl border border-fvazul-200/35 bg-fvazul-200/10 px-5 py-5 text-center font-display text-lg font-bold tracking-[0.28em] text-fvplata-50 outline-none transition duration-300 hover:border-fvazul-300 hover:bg-fvazul-400/20 focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-4 focus-visible:ring-offset-transparent"
              >
                <span
                  aria-hidden="true"
                  data-nav-underline
                  class="pointer-events-none absolute inset-x-6 bottom-3 h-px bg-fvplata-300"
                />
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>

<style>
  [data-logo-reveal] > img {
    will-change: opacity, transform;
    transform-origin: center center;
  }

  [data-logo-chrome] {
    filter: drop-shadow(0 0 10px color-mix(in srgb, var(--color-fvplata-300) 58%, transparent));
  }

  @media (prefers-reduced-motion: reduce) {
    [data-logo-reveal] > img {
      transition: none;
    }
  }

  [data-nav-link] [data-nav-underline] {
    clip-path: inset(0 100% 0 0);
  }
</style>

<script>
  import { gsap } from "gsap";

  const SCROLL_THRESHOLD = 24;
  const LOGO_REVEAL_DURATION = 1.05;

  let scrollAbortController: AbortController | null = null;
  let menuAbortController: AbortController | null = null;
  let navUnderlineAbortController: AbortController | null = null;
  let logoHoverAbortController: AbortController | null = null;
  let internalNavigationAbortController: AbortController | null = null;
  let logoRevealTimeline: gsap.core.Timeline | null = null;

  function setupHeaderScroll() {
    const header = document.querySelector("[data-header]");
    if (!header) return;

    scrollAbortController?.abort();
    scrollAbortController = new AbortController();

    const update = () => {
      const scrolled = window.scrollY > SCROLL_THRESHOLD;
      if (scrolled) {
        header.setAttribute("data-scrolled", "true");
      } else {
        header.removeAttribute("data-scrolled");
      }
    };

    update();
    window.addEventListener("scroll", update, {
      passive: true,
      signal: scrollAbortController.signal,
    });
  }

  function setupInternalNavigation() {
    const links = document.querySelectorAll("[data-nav-link]");
    
    internalNavigationAbortController?.abort();
    internalNavigationAbortController = new AbortController();
    const { signal } = internalNavigationAbortController;

    links.forEach((link) => {
      link.addEventListener("click", (e) => {
        const href = link.getAttribute("href");

        if (href && href.startsWith("#")) {
          e.preventDefault();
          
          const targetSection = document.querySelector(href);
          if (!targetSection) return;

          const headerOffset = 75; 
          const elementPosition = targetSection.getBoundingClientRect().top;
          const offsetPosition = elementPosition + window.scrollY - headerOffset;

          const scrollTarget = { y: window.scrollY };
          gsap.to(scrollTarget, {
            y: offsetPosition,
            duration: 1.2,
            ease: "power4.out",
            onUpdate: () => window.scrollTo(0, scrollTarget.y)
          });
        } else if (href === "#" || href === "/") {
          e.preventDefault();
          const scrollTarget = { y: window.scrollY };
          gsap.to(scrollTarget, {
            y: 0,
            duration: 1.2,
            ease: "power4.out",
            onUpdate: () => window.scrollTo(0, scrollTarget.y)
          });
        }
      }, { signal });
    });
  }

  function setupLogoReveal() {
    const logo = document.querySelector("[data-logo-reveal]") as HTMLElement | null;
    const baseLogo = logo?.querySelector("[data-logo-base]") as HTMLElement | null;
    const chromeLogo = logo?.querySelector("[data-logo-chrome]") as HTMLElement | null;
    const anniversaryLogo = logo?.querySelector("[data-logo-anniversary]") as HTMLElement | null;

    if (!logo || !baseLogo || !chromeLogo || !anniversaryLogo) return;

    logoRevealTimeline?.kill();
    gsap.killTweensOf([baseLogo, chromeLogo, anniversaryLogo]);
    
    gsap.set(baseLogo, { opacity: 1, scale: 1, y: 0, rotate: 0 });
    gsap.set(chromeLogo, { opacity: 0, scale: 0.965, y: 1, rotate: 0 });
    gsap.set(anniversaryLogo, { opacity: 0, scale: 0.96, y: 4, rotate: 0 });

    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const navEntry = performance.getEntriesByType("navigation")[0] as PerformanceNavigationTiming | undefined;
    const isReload = navEntry?.type === "reload";

    if (!isReload) return;

    logoRevealTimeline = gsap
      .timeline({ defaults: { ease: "power2.out" } })
      .to(baseLogo, { opacity: 0.2, scale: 0.985, duration: 0.18 }, 0)
      .to(anniversaryLogo, { opacity: 1, scale: 1, y: 0, duration: 0.34, ease: "power3.out" }, 0.08)
      .to(anniversaryLogo, { opacity: 0, scale: 1.02, y: -2, duration: 0.3, ease: "power2.in" }, `+=${LOGO_REVEAL_DURATION - 0.48}`)
      .to(baseLogo, { opacity: 1, scale: 1, y: 0, duration: 0.18 }, "<");
  }

  function setupLogoHover() {
    const logo = document.querySelector("[data-logo-reveal]") as HTMLElement | null;
    const baseLogo = logo?.querySelector("[data-logo-base]") as HTMLElement | null;
    const chromeLogo = logo?.querySelector("[data-logo-chrome]") as HTMLElement | null;

    if (!logo || !baseLogo || !chromeLogo) return;

    logoHoverAbortController?.abort();
    logoHoverAbortController = new AbortController();
    const { signal } = logoHoverAbortController;

    const showChrome = () => {
      gsap.killTweensOf([baseLogo, chromeLogo]);
      gsap.to(baseLogo, { opacity: 0, scale: 0.975, y: 1, duration: 0.32, ease: "power2.out" });
      gsap.to(chromeLogo, { opacity: 1, scale: 1, y: 0, duration: 0.42, ease: "power3.out" });
    };

    const showBase = () => {
      gsap.killTweensOf([baseLogo, chromeLogo]);
      gsap.to(chromeLogo, { opacity: 0, scale: 0.965, y: 1, duration: 0.28, ease: "power2.inOut" });
      gsap.to(baseLogo, { opacity: 1, scale: 1, y: 0, duration: 0.34, ease: "power2.out" });
    };

    logo.addEventListener("pointerenter", showChrome, { signal });
    logo.addEventListener("pointerleave", showBase, { signal });
    logo.addEventListener("focusin", showChrome, { signal });
    logo.addEventListener("focusout", showBase, { signal });
  }

  function setupMobileMenu() {
    const header = document.querySelector("[data-header]") as HTMLElement | null;
    const menu = document.querySelector("[data-mobile-menu]") as HTMLElement | null;
    const button = document.querySelector("[data-mobile-menu-button]") as HTMLButtonElement | null;
    const links = Array.from(document.querySelectorAll("[data-mobile-menu-link]")) as HTMLAnchorElement[];

    if (!header || !menu || !button) return;

    menuAbortController?.abort();
    menuAbortController = new AbortController();
    const { signal } = menuAbortController;

    const setMenuOpen = (isOpen: boolean) => {
      header.setAttribute("data-menu-open", String(isOpen));
      menu.setAttribute("data-open", String(isOpen));
      button.setAttribute("data-open", String(isOpen));
      menu.setAttribute("aria-hidden", String(!isOpen));
      menu.inert = !isOpen;
      button.setAttribute("aria-expanded", String(isOpen));
      button.setAttribute("aria-label", isOpen ? "Cerrar menú" : "Abrir menú");

      const label = button.querySelector(".sr-only");
      if (label) label.textContent = isOpen ? "Cerrar menú" : "Abrir menú";

      document.documentElement.classList.toggle("overflow-hidden", isOpen);
    };

    setMenuOpen(false);

    button.addEventListener("click", () => {
      setMenuOpen(button.getAttribute("aria-expanded") !== "true");
    }, { signal });

    links.forEach((link) => {
      link.addEventListener("click", () => {
        setMenuOpen(false);
      }, { signal });
    });

    window.addEventListener("keydown", (event) => {
      if (event.key === "Escape") setMenuOpen(false);
    }, { signal });
  }

  function setupNavUnderline() {
    const links = Array.from(document.querySelectorAll("[data-nav-link]")) as HTMLAnchorElement[];

    navUnderlineAbortController?.abort();
    navUnderlineAbortController = new AbortController();
    const { signal } = navUnderlineAbortController;

    links.forEach((link) => {
      const underline = link.querySelector("[data-nav-underline]");
      if (!underline) return;

      gsap.set(underline, { clipPath: "inset(0 100% 0 0)" });

      link.addEventListener("pointerenter", () => {
        gsap.killTweensOf(underline);
        gsap.to(underline, { clipPath: "inset(0 0% 0 0)", duration: 0.3, ease: "power2.out" });
      }, { signal });

      link.addEventListener("pointerleave", () => {
        gsap.killTweensOf(underline);
        gsap.to(underline, {
          clipPath: "inset(0 0% 0 100%)",
          duration: 0.3,
          ease: "power2.inOut",
          onComplete: () => {
            gsap.set(underline, { clipPath: "inset(0 100% 0 0)" });
          },
        });
      }, { signal });
    });
  }

  document.addEventListener("astro:page-load", () => {
    setupHeaderScroll();
    setupLogoReveal();
    setupLogoHover();
    setupMobileMenu();
    setupNavUnderline();
    setupInternalNavigation(); 
  });
</script>