---
// src/components/FaqSection.astro
interface FaqItem {
  question: string;
  answer: string;
}

interface Props {
  faqs?: readonly FaqItem[]; // Le agregamos el "?" para decirle a TS que puede ser opcional
}

// 🛡️ Clavamos un array vacío de respaldo por si viene undefined
const { faqs = [] } = Astro.props;
---


<section
  id="faq"
  class="faq-section relative w-full overflow-hidden bg-primary px-4 py-24 sm:px-6 lg:py-32 border-t border-fvantracita-900"
  aria-labelledby="faq-title"
  itemscope
  itemtype="https://schema.org/FAQPage"
>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 h-px bg-linear-to-r from-transparent via-fvplata-300/20 to-transparent z-10"
  >
  </div>

  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-x-0 top-0 -z-0 h-72 bg-[radial-gradient(ellipse_at_top,_var(--color-fvplata-300)_0%,_transparent_70%)] opacity-[0.03]"
  >
  </div>

  <div class="relative mx-auto flex max-w-4xl flex-col items-center">
    
    <div class="text-center mb-16 space-y-2">
      <span class="font-overpass text-xs font-semibold uppercase tracking-widest text-fvplata-300">
        // Respuestas Inmediatas
      </span>
      <h2 id="faq-title" class="font-primary text-3xl font-black tracking-[0.18em] text-white sm:text-4xl md:text-5xl uppercase">
        DESPEJÁ TUS DUDAS
      </h2>
      <p class="font-overpass text-sm font-light tracking-wide text-fvantracita-400 max-w-xl mx-auto text-balance">
        Todo lo que necesitas saber sobre gestoría, formas de pago, permutas y revisión técnica de nuestros seleccionados.
      </p>
    </div>

    <ul class="w-full divide-y divide-fvantracita-900/60 border-y border-fvantracita-900/60">
      {
        faqs.map(({ question, answer }) => (
          <li>
            <details
              class="faq-item group bg-fvantracita-950/20 transition duration-300 open:bg-fvantracita-950/40 hover:bg-fvantracita-950/30"
              name="faq"
              itemprop="mainEntity"
              itemscope
              itemtype="https://schema.org/Question"
            >
              <summary class="flex min-h-20 cursor-pointer list-none items-center justify-between gap-5 px-4 py-5 outline-none marker:hidden focus-visible:ring-2 focus-visible:ring-white/20 focus-visible:ring-offset-2 focus-visible:ring-offset-black sm:min-h-24 sm:px-6 sm:py-6 [&::-webkit-details-marker]:hidden">
                <h3
                  itemprop="name"
                  class="font-primary text-sm sm:text-base leading-snug font-bold tracking-wider text-balance text-white/90 transition duration-300 group-open:text-white"
                >
                  {question}
                </h3>
                
                <span
                  class="relative flex size-9 shrink-0 items-center justify-center rounded-xl border border-fvantracita-800 bg-black/40 text-fvantracita-400 transition duration-300 group-open:rotate-45 group-open:border-white group-open:bg-white group-open:text-black sm:size-10"
                  aria-hidden="true"
                >
                  <span class="absolute h-px w-3.5 bg-current"></span>
                  <span class="absolute h-3.5 w-px bg-current"></span>
                </span>
              </summary>

              <div
                class="faq-answer-shell px-4 pb-6 pr-14 sm:px-6 sm:pr-20"
                itemprop="acceptedAnswer"
                itemscope
                itemtype="https://schema.org/Answer"
              >
                <p
                  itemprop="text"
                  class="faq-answer-body max-w-3xl font-overpass text-xs sm:text-sm font-light leading-relaxed text-pretty text-fvantracita-400"
                >
                  {answer}
                </p>
              </div>
            </details>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .faq-section {
    --faq-ease-out: cubic-bezier(0.23, 1, 0.32, 1);
    interpolate-size: allow-keywords;
  }

  .faq-item {
    position: relative;
  }

  /* Línea reflectiva superior reactiva al abrir el acordeón */
  .faq-item::before {
    content: '';
    position: absolute;
    inset-inline: 0;
    top: -1px;
    height: 1px;
    background-image: linear-gradient(to right, transparent, var(--color-fvplata-300), transparent);
    transform: scaleX(0);
    transform-origin: center;
    transition: transform 300ms var(--faq-ease-out);
    z-index: 10;
  }

  .faq-item[open]::before {
    transform: scaleX(1);
  }

  /* Motor nativo de expansión fluida (Tailwind 4 / CSS moderno) */
  .faq-item::details-content {
    block-size: 0;
    overflow: clip;
    transition:
      block-size 320ms var(--faq-ease-out),
      content-visibility 320ms var(--faq-ease-out);
    transition-behavior: allow-discrete;
  }

  .faq-item[open]::details-content {
    block-size: auto;
  }

  /* Animación de emergencia de la prosa interna */
  .faq-answer-body {
    opacity: 0;
    transform: translateY(-4px);
    transition:
      opacity 200ms var(--faq-ease-out),
      transform 250ms var(--faq-ease-out);
  }

  .faq-item[open] .faq-answer-body {
    opacity: 1;
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .faq-item::before,
    .faq-item::details-content,
    .faq-answer-body {
      transition: none;
    }
    .faq-answer-body {
      transform: none;
    }
  }
</style>