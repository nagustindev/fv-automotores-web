---
interface Props {
	label: string;
	value?: string | number;
	variant?: 'glass' | 'plata';
	compact?: boolean;
	class?: string;
	id?: string;
}

const {
	label,
	value,
	variant = 'glass',
	compact = false,
	class: className = '',
	...rest
} = Astro.props;

const variants = {
	glass: [
		'border-fv-antracita-700/5 bg-primary/40 text-white/85 shadow-[0_0_0_1px_rgba(255,255,255,0.04)] hover:bg-primary/50 hover:text-fvplata-50 hover:shadow-[0_0_0_1px_rgba(198,210,219,0.14),0_0_18px_rgba(198,210,219,0.22)]',
	],
	plata: [
		'border-fvplata-300/80 bg-fvplata-300 text-fvantracita-950 shadow-[0_0_0_1px_rgba(255,255,255,0.18)] hover:bg-fvplata-100 hover:text-fvantracita-950 hover:shadow-[0_0_0_1px_rgba(198,210,219,0.18),0_0_18px_rgba(198,210,219,0.28)]',
	],
} as const;

const badgeVariant = variant === 'plata' ? 'plata' : 'glass';

const baseClasses = [
	'group relative inline-flex items-center overflow-hidden rounded-full border text-center backdrop-blur-md backdrop-saturate-150 font-primary uppercase tracking-[0.34em] transition duration-300 ease-out focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-fvazul-300 focus-visible:ring-offset-2 focus-visible:ring-offset-transparent active:translate-y-0',
	compact ? 'justify-center gap-2 px-4 py-2 text-[0.62rem]' : 'justify-between gap-3 px-4 py-2 text-[0.65rem]',
	variants[badgeVariant],
].join(' ');

const valueClasses = [
	'relative z-10 font-overpass text-[0.8rem] font-semibold tracking-[0.12em] normal-case',
].join(' ');
---

<span {...rest} class:list={[baseClasses, className]}>
	<span data-vehicle-badge-label class="relative z-10 text-[0.58rem] opacity-80">{label}</span>
	{!compact && <span data-vehicle-badge-value class={valueClasses}>{value}</span>}
</span>
