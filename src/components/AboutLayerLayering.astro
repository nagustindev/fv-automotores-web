---

---

<section
  data-experience-container
  class="relative flex h-dvh w-full items-center justify-center overflow-hidden"
>
  <div class="relative flex items-center justify-center text-center select-none w-full max-w-7xl px-4">
    
    <div 
      data-layer="bg" 
      class="flex flex-col items-center justify-center space-y-4 will-change-transform"
    >
      <h2 class="font-primary text-[11vw] font-black uppercase leading-none text-transparent [-webkit-text-stroke:2px_rgba(255,255,255,0.9)] [text-stroke:2px_rgba(255,255,255,0.9)] tracking-tight whitespace-nowrap">
        25 AÑOS
      </h2>
      
      <h3 class="font-primary text-[10vw] font-black uppercase leading-none text-transparent [-webkit-text-stroke:1.5px_rgba(255,255,255,0.8)] [text-stroke:1.5px_rgba(255,255,255,0.8)] tracking-widest">
        de
      </h3>
    </div>

    <h2 
      data-layer="fg" 
      class="absolute font-primary text-[11vw] font-black uppercase tracking-tight text-white leading-none will-change-transform opacity-0 pointer-events-none drop-shadow-[0_0_50px_rgba(0,0,0,0.95)]"
    >
      EXPERIENCIA
    </h2>

  </div>
</section>

<style>
  [data-layer] {
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    transform-style: preserve-3d;
  }
</style>

<script>
  import { gsap } from "gsap";
  import { ScrollTrigger } from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  function setupMercedesStyleTimeline() {
    const section = document.querySelector("[data-experience-container]");
    if (!section) return;

    const bgLayer = section.querySelector('[data-layer="bg"]');
    const fgLayer = section.querySelector('[data-layer="fg"]');

    if (!bgLayer || !fgLayer) return;

    gsap.set(fgLayer, { y: "25vh", opacity: 0, scale: 0.95 });

    const tl = gsap.timeline({
      scrollTrigger: {
        trigger: section,
        start: "top top",
        end: "+=2000", 
        scrub: 1,      
        pin: true,     
        invalidateOnRefresh: true
      }
    });

    tl.to(bgLayer, {
      opacity: 0.12,         
      scale: 0.95,           
      duration: 1.5,
      ease: "power2.inOut"
    })
    .to(fgLayer, {
      opacity: 1,            
      y: "0vh",              
      scale: 1,
      duration: 1.8,
      ease: "power2.out"
    }, "<+=0.1");           

    tl.to({}, { duration: 0.7 });
  }

  document.addEventListener("astro:page-load", setupMercedesStyleTimeline);
</script>