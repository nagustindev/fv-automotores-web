---
import VehicleCard from '@/components/VehicleCard.astro';
import type { Vehicle } from '@/types/vehicle';

interface Props {
  vehicles?: Vehicle[];
}

// Recibimos los vehículos de Sanity por medio de las Props de Astro
const { vehicles = [] }: Props = Astro.props;
---

<div class="grid grid-cols-1 md:grid-cols-2 gap-6 w-full max-w-6xl mx-auto relative z-10">
  {vehicles && vehicles.map((vehicle: Vehicle) => (
    <VehicleCard vehicle={vehicle} />
  ))}
</div>