---
import ArrowRightIcon from "@/assets/svg/arrow-right.svg";
import PlayIcon from "@/assets/svg/play.svg";

const SOCIAL_LINKS = {
  presentacionLocal:
    "https://www.tiktok.com/@fabioviolaautomotores/video/7633794616025795861",
  promoMundial:
    "https://www.tiktok.com/@fabioviolaautomotores/video/7650236181799587092",
  presentacionJuampi:
    "https://www.tiktok.com/@fabioviolaautomotores/video/7601529228802182420",
};
---

<div class="w-full">
  <div class="grid gap-4 md:grid-cols-12 lg:grid-cols-12">
    <a
      href={SOCIAL_LINKS.presentacionLocal}
      target="_blank"
      rel="noopener noreferrer"
      class="group relative min-h-125 overflow-hidden rounded-3xl border border-fvplata-300/30 bg-black shadow-xl transition duration-500 ease-out hover:-translate-y-1 hover:border-fvplata-100/60 md:col-span-12 lg:col-span-7"
    >
      <img
        src="/presentacion.webp"
        alt="Presentación FV"
        class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-black/90 to-transparent"
      >
      </div>

      <div
        class="absolute left-1/2 top-1/2 grid size-20 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-fvplata-300/55 bg-white/10 backdrop-blur-md transition group-hover:scale-110"
      >
        <PlayIcon class="size-8 text-white" />
      </div>

      <div class="absolute bottom-0 p-8">
        <p class="font-primary text-2xl font-bold tracking-[0.35em] text-white">
          PRESENTACIÓN SHOWROOM
        </p>
        <div
          class="mt-4 inline-flex items-center gap-2 text-[0.66rem] font-semibold uppercase tracking-[0.42em] text-fvplata-300"
        >
          <span>VER VÍDEO</span>
          <ArrowRightIcon class="size-4" />
        </div>
      </div>
    </a>

    <div
      class="grid gap-4 md:grid-cols-2 md:col-span-12 lg:grid-cols-1 lg:col-span-5"
    >
      <a
        href={SOCIAL_LINKS.promoMundial}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative min-h-60 overflow-hidden rounded-3xl border border-fvplata-300/30 bg-black transition duration-500 hover:border-fvplata-100/60"
      >
        <img
          src="/promo-mundial.webp"
          alt="Promo Mundial"
          class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"
        >
        </div>

        <div
          class="absolute left-6 top-6 grid size-12 place-items-center rounded-full border border-fvplata-300/55 bg-white/10 backdrop-blur-md transition group-hover:scale-110"
        >
          <PlayIcon class="size-5 text-white" />
        </div>

        <div class="absolute bottom-0 p-6">
          <p
            class="font-primary text-xl font-bold tracking-[0.22em] text-white"
          >
            PROMO MUNDIAL
          </p>
          <div
            class="mt-2 inline-flex items-center gap-2 text-[0.62rem] uppercase tracking-[0.45em] text-fvplata-300"
          >
            <span>VER VIDEO</span>
            <ArrowRightIcon class="size-3" />
          </div>
        </div>
      </a>

      <a
        href={SOCIAL_LINKS.presentacionJuampi}
        target="_blank"
        rel="noopener noreferrer"
        class="group relative min-h-60 overflow-hidden rounded-3xl border border-fvplata-300/30 bg-black transition duration-500 hover:border-fvplata-100/60"
      >
        <img
          src="/presentacion-juampi.webp"
          alt="Fabio y Juampi"
          class="absolute inset-0 h-full w-full object-cover transition duration-700 group-hover:scale-105"
        />
        <div
          class="absolute inset-0 bg-gradient-to-t from-black/80 to-transparent"
        >
        </div>

        <div
          class="absolute left-6 top-6 grid size-12 place-items-center rounded-full border border-fvplata-300/55 bg-white/10 backdrop-blur-md transition group-hover:scale-110"
        >
          <PlayIcon class="size-5 text-white" />
        </div>

        <div class="absolute bottom-0 p-6">
          <p
            class="font-primary text-xl font-bold tracking-[0.22em] text-white"
          >
            CONOCENOS: JUAMPI
          </p>
          <div
            class="mt-2 inline-flex items-center gap-2 text-[0.62rem] uppercase tracking-[0.45em] text-fvplata-300"
          >
            <span>VER VIDEO</span>
            <ArrowRightIcon class="size-3" />
          </div>
        </div>
      </a>
    </div>
  </div>
</div>
