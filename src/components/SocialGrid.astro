---
import ArrowRightIcon from "@/assets/svg/arrow-right.svg";

const SOCIAL_LINKS = {
  presentacionLocal: "https://www.tiktok.com/@fabioviolaautomotores/video/7633794616025795861",
  trayectoria: "LINK_A_POST_DE_LOS_25_ANOS",
  consejoValor: "LINK_A_REEL_DE_CONSEJOS_O_ENTREGA",
};
---

<div class="w-full">
	<div class="grid gap-4 lg:grid-cols-12">
		<a
			href={SOCIAL_LINKS.presentacionLocal}
			target="_blank"
			rel="noopener noreferrer"
			class="group relative min-h-125 overflow-hidden rounded-3xl border border-fvplata-300/30 bg-black shadow-[0_0_0_1px_rgba(198,210,219,0.08),0_18px_50px_rgba(0,0,0,0.5)] transition duration-500 ease-out hover:-translate-y-1 hover:border-fvplata-100/60 hover:shadow-[0_0_0_1px_rgba(198,210,219,0.18),0_24px_70px_rgba(0,0,0,0.62),0_0_28px_rgba(198,210,219,0.14)] lg:col-span-7"
		>
			<picture class="absolute inset-0">
				<source type="image/webp" srcset="/presentacion.webp 1x" />
				<img
					src="/presentacion.webp"
					alt="Presentación FV Automotores"
					class="h-full w-full object-cover object-center transition duration-700 ease-out group-hover:scale-105 group-hover:opacity-100"
					decoding="async"
					loading="lazy"
				/>
			</picture>

			<div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.14)_0%,transparent_40%),linear-gradient(to_top,rgba(0,0,0,0.92)_0%,rgba(0,0,0,0.5)_42%,rgba(0,0,0,0.22)_100%)] transition duration-500 group-hover:bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.22)_0%,transparent_38%),linear-gradient(to_top,rgba(0,0,0,0.95)_0%,rgba(0,0,0,0.38)_40%,rgba(0,0,0,0.12)_100%)]"></div>

			<div class="absolute inset-x-4 top-4 sm:inset-x-6 sm:top-6 lg:inset-x-8 lg:top-7">
				<p class="text-center font-primary text-4xl font-bold tracking-[0.18em] text-white/90 drop-shadow-[0_2px_10px_rgba(0,0,0,0.55)] transition duration-500 group-hover:scale-[1.01] sm:text-5xl lg:text-7xl">
					PRESENTACION
				</p>
			</div>

			<div class="absolute left-1/2 top-1/2 grid size-20 -translate-x-1/2 -translate-y-1/2 place-items-center rounded-full border border-fvplata-300/55 bg-white/12 text-white shadow-[0_0_0_1px_rgba(255,255,255,0.08),0_0_26px_rgba(198,210,219,0.18)] backdrop-blur-md transition duration-500 group-hover:scale-110 group-hover:border-fvplata-100/70 group-hover:bg-white/18">
				<span class="translate-x-px text-2xl leading-none">▶</span>
			</div>

			<div class="absolute inset-x-0 bottom-0 p-5 sm:p-6 lg:p-8">
				<div class="max-w-xl">
					<p class="font-primary text-[0.92rem] font-bold tracking-[0.35em] text-fvplata-100/95 sm:text-[1.05rem]">
						LA PRESENTACIÓN
					</p>
					<div class="mt-4 inline-flex items-center gap-1 text-[0.66rem] font-semibold uppercase tracking-[0.42em] text-fvplata-300 transition duration-300 group-hover:text-white">
						<span>VER VÍDEO</span>
						<ArrowRightIcon class="size-4 shrink-0 transition duration-300 group-hover:translate-x-1" />
					</div>
				</div>
			</div>
		</a>

		<div class="grid gap-4 lg:col-span-5">
			<a
				href={SOCIAL_LINKS.trayectoria}
				target="_blank"
				rel="noopener noreferrer"
				class="group relative min-h-60 overflow-hidden rounded-2xl border border-fvplata-300/18 bg-[#070a12] shadow-[0_0_0_1px_rgba(198,210,219,0.06),0_16px_36px_rgba(0,0,0,0.38)] transition duration-500 ease-out hover:-translate-y-1 hover:border-fvplata-100/45 hover:shadow-[0_0_0_1px_rgba(198,210,219,0.14),0_22px_50px_rgba(0,0,0,0.5),0_0_24px_rgba(198,210,219,0.08)]"
			>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08)_0%,transparent_42%),linear-gradient(to_top,rgba(0,0,0,0.96)_0%,rgba(4,8,18,0.92)_100%)] transition duration-500 group-hover:bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.14)_0%,transparent_42%),linear-gradient(to_top,rgba(0,0,0,0.98)_0%,rgba(4,8,18,0.86)_100%)]"></div>
				<div class="absolute inset-0 bg-[linear-gradient(135deg,transparent_0%,rgba(255,255,255,0.08)_45%,transparent_60%)] opacity-30 transition duration-500 group-hover:opacity-50"></div>

				<div class="relative z-10 flex h-full flex-col items-center justify-center px-6 py-8 text-center">
					<p class="font-primary text-3xl font-bold tracking-[0.22em] text-fvplata-100 sm:text-4xl">
						TIPS
					</p>
					<div class="mt-5 flex items-center gap-3 text-[0.62rem] font-semibold uppercase tracking-[0.45em] text-fvplata-300 transition duration-300 group-hover:text-white">
						<span class="h-px w-10 bg-current/35"></span>
						<span>PRÓXIMAMENTE</span>
						<span class="h-px w-10 bg-current/35"></span>
					</div>
				</div>
			</a>

			<a
				href={SOCIAL_LINKS.consejoValor}
				target="_blank"
				rel="noopener noreferrer"
				class="group relative min-h-60 overflow-hidden rounded-2xl border border-fvplata-300/18 bg-[#070a12] shadow-[0_0_0_1px_rgba(198,210,219,0.06),0_16px_36px_rgba(0,0,0,0.38)] transition duration-500 ease-out hover:-translate-y-1 hover:border-fvplata-100/45 hover:shadow-[0_0_0_1px_rgba(198,210,219,0.14),0_22px_50px_rgba(0,0,0,0.5),0_0_24px_rgba(198,210,219,0.08)]"
			>
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.08)_0%,transparent_42%),linear-gradient(to_top,rgba(0,0,0,0.96)_0%,rgba(4,8,18,0.92)_100%)] transition duration-500 group-hover:bg-[radial-gradient(circle_at_top,rgba(255,255,255,0.14)_0%,transparent_42%),linear-gradient(to_top,rgba(0,0,0,0.98)_0%,rgba(4,8,18,0.86)_100%)]"></div>
				<div class="absolute inset-0 bg-[linear-gradient(135deg,transparent_0%,rgba(255,255,255,0.08)_45%,transparent_60%)] opacity-30 transition duration-500 group-hover:opacity-50"></div>

				<div class="relative z-10 flex h-full flex-col items-center justify-center px-6 py-8 text-center">
					<p class="font-primary text-3xl font-bold tracking-[0.22em] text-fvplata-100 sm:text-4xl">
						FABIO Y JUAMPI
					</p>
					<div class="mt-5 flex items-center gap-3 text-[0.62rem] font-semibold uppercase tracking-[0.45em] text-fvplata-300 transition duration-300 group-hover:text-white">
						<span class="h-px w-10 bg-current/35"></span>
						<span>PRÓXIMAMENTE</span>
						<span class="h-px w-10 bg-current/35"></span>
					</div>
				</div>
			</a>
		</div>
	</div>
</div>
