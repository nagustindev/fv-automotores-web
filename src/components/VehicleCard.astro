---
import { urlFor } from '@/lib/sanity';

const { vehicle } = Astro.props;
---

<div class="bg-[#242424] border border-zinc-800 rounded-xl overflow-hidden group transition-all duration-300">
  
  {/* Imagen Principal de Portada */}
  <div 
    class="relative overflow-hidden aspect-16/10 bg-zinc-900 cursor-pointer"
    data-open-modal
    data-vehicle={JSON.stringify(vehicle)}
  >
    {vehicle.mainImage && (
      <img 
        src={urlFor(vehicle.mainImage).width(600).format('webp').url()} 
        alt={vehicle.title}
        loading="lazy"
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
      />
    )}
    
    {/* Título sobre la imagen */}
    <div class="absolute inset-0 flex flex-col justify-end p-6 bg-gradient-to-t from-black/80 to-transparent">
      <div class="flex justify-between items-end gap-2">
        <h3 class="font-primary font-bold text-white text-xl uppercase tracking-wide">
          {vehicle.title}
        </h3>
      </div>
    </div>
  </div>
</div>