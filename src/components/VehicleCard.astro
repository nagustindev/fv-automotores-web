---
interface Props {
  id: string;
  image: string;
  name: string;
  price: string;
}

const { id, image, name, price } = Astro.props;
---

<a href={`/vehicles/${id}`} class="group relative overflow-hidden rounded-lg shadow-lg transition-transform duration-300 hover:shadow-xl hover:scale-105 block">
  <div class="relative h-96 w-full overflow-hidden bg-fvantracita-950">
    <img
      src={image}
      alt={name}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"
    />
    
    <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>

    <div class="absolute inset-0 flex flex-col justify-end p-4">
      <p class="text-xl font-bold text-fvplata-300">
        {price}
      </p>
      <h3 class="text-2xl font-bold text-white font-primary tracking-wide mt-1">
        {name}
      </h3>
    </div>
  </div>
</a>
