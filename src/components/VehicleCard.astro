---
interface Props {
  id: string;
  image: string;
  name: string;
  price: string;
}

const { id, image, name, price } = Astro.props;
---

<a href={`/vehicles/${id}`} class="group relative block overflow-hidden rounded-lg shadow-lg transition-transform duration-300 hover:shadow-xl hover:scale-105">
  <div class="relative h-88 w-full overflow-hidden bg-fvantracita-950 sm:h-96 lg:h-96">
    <img
      src={image}
      alt={name}
      class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-110"
    />
    
    <div class="absolute inset-0 bg-linear-to-t from-black/80 via-black/20 to-transparent"></div>

    <div class="absolute inset-0 flex flex-col justify-end p-4 sm:p-5">
      <p class="text-lg font-bold text-fvplata-300 sm:text-xl">
        {price}
      </p>
      <h3 class="mt-1 text-xl font-bold text-white font-primary tracking-wide sm:text-2xl">
        {name}
      </h3>
    </div>
  </div>
</a>
